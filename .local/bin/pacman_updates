#!/usr/bin/env zsh

cache="${XDG_CACHE_HOME:-$HOME/.cache}/pacman_updates"
ttl=900

if [[ -f $cache ]] && (( $(date +%s) - $(stat -c %Y "$cache") < ttl )); then
    count=$(<"$cache")
else
    count=$(checkupdates 2>/dev/null | grep -c '^[^[:space:]]')
    echo "$count" > "$cache"
fi

if (( count == 0 )); then
    echo "ůįģĮ no updates"
    exit 0
fi

if (( count <= 5 )); then
    dots=$(printf '‚ÄĘ %.0s' $(seq 1 "$count"))
    echo "ůįģĮ $dots ($count updates)"
else
    echo "ůįģĮ ‚ÄĘ ‚ÄĘ ‚ÄĘ ‚ÄĘ ‚ÄĘ ‚ÄĘ ‚ÄĘ ‚ÄĘ ůįä† ($count updates)"
fi
